{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bd2modmanager",
  "version": "4.0.0",
  "identifier": "com.bruhnn.BD2ModManager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BD2ModManager",
        "width": 1000,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 600,
        "dragDropEnabled": true,
        "visible": false,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "devtools": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.ico",
      "icons/24x24.ico",
      "icons/32x32.ico",
      "icons/64x64.ico",
      "icons/96x96.ico",
      "icons/128x128.ico",
      "icons/192x192.ico",
      "icons/256x256.ico"
    ],
    "resources": {
      "bundled_tools/": "bundled_tools/",
      "data/": "data/"
    }
  }
}
