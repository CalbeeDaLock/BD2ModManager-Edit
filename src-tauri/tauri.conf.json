{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BD2ModManager",
  "version": "4.0.5",
  "identifier": "com.bruhnn.BD2ModManager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BD2ModManager",
        "width": 1000,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 600,
        "dragDropEnabled": true,
        "visible": false,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "devtools": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/16x16.ico",
      "icons/24x24.ico",
      "icons/32x32.ico",
      "icons/64x64.ico",
      "icons/96x96.ico",
      "icons/128x128.ico",
      "icons/192x192.ico",
      "icons/256x256.ico"
    ],
    "resources": {
      "resources/BD2ModPreview.exe": "resources/BD2ModPreview.exe"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzQ0IxMTRDN0U0NTk1QzYKUldUR2xVVitUQkhMODZhcEJGNEUxanM4VnhsV005ekRjb2FwR1QyN3dlMFdPbXZlUXNKUUJoWGsK",
      "endpoints": [
        "https://shy-waterfall-2797.bruhnn.workers.dev/latest.json"
      ]
    }
  }
}
